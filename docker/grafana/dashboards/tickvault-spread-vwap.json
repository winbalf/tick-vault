            "type": "grafana-bigquery-datasource",
            "uid": "bq_tickvault"
          },
          "editorMode": "code",
          "format": 1,
          "rawSql": "SELECT DATETIME(metric_ts) AS time, 'vwap' AS metric, CAST(vwap AS FLOAT64) AS value FROM `${gold_dataset}.fct_market_metrics` WHERE exchange = '${exchange}' AND symbol = '${symbol}' AND metric_ts >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 2 DAY) UNION ALL SELECT DATETIME(metric_ts) AS time, 'mid_price' AS metric, CAST(avg_mid_price AS FLOAT64) AS value FROM `${gold_dataset}.fct_market_metrics` WHERE exchange = '${exchange}' AND symbol = '${symbol}' AND metric_ts >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 2 DAY) ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "VWAP vs mid-price",
      "type": "timeseries"
