          "editorMode": "code",
          "format": 1,
          "rawSql": "SELECT DATETIME(metric_ts) AS time, CONCAT(exchange, ':', symbol) AS metric, CAST(spread_bps AS FLOAT64) AS spread_bps FROM `${gold_dataset}.fct_market_metrics` WHERE spread_bps IS NOT NULL AND metric_ts >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 2 DAY) ORDER BY 1",
