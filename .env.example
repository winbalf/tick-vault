REDPANDA_BROKERS=redpanda:9092

BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
BINANCE_SYMBOL=BTCUSDT

KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_PAIR=XBT/USDT
KRAKEN_BOOK_DEPTH=10

TRADES_TOPIC=raw.trades.v1
DEPTH_TOPIC=raw.depth.v1
DLQ_TOPIC=dlq.trades

# CoinGecko / CryptoCompare → raw.coingecko.v1, raw.cryptocompare.v1 (Flink bronze stream_kind coingecko / cryptocompare)
# COINGECKO_ENABLED=true
# COINGECKO_TOPIC=raw.coingecko.v1
# COINGECKO_POLL_SECONDS=60
# COINGECKO_ID=bitcoin
# CRYPTOCOMPARE_ENABLED=true
# CRYPTOCOMPARE_TOPIC=raw.cryptocompare.v1
# CRYPTOCOMPARE_POLL_SECONDS=60
# CRYPTOCOMPARE_FSYM=BTC

RECONNECT_BASE_SECONDS=1
RECONNECT_MAX_SECONDS=30

# --- Google Cloud (dbt / BigQuery; not loaded automatically into your shell — export before dbt) ---
# Same service account should be able to run BigQuery jobs and read gs:// objects for bronze external tables.
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/tick-vault/keys/your-sa.json
# GCS_BUCKET=your-bucket-name
# GCP_CLIENT_EMAIL=service-account@your-gcp-project-id.iam.gserviceaccount.com
# GCP_TOKEN_URI=https://oauth2.googleapis.com/token
# GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional: document a default BQ dataset name (dbt uses tickvault_bronze / silver / gold via dbt_project vars).
# BIGQUERY_DATASET=tickvault_silver

# --- Phase 2 (Flink bronze sink; used by flink-submit-bronze compose service) ---
# KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
# TRADES_TOPIC=raw.trades.v1
# DEPTH_TOPIC=raw.depth.v1
# BRONZE_SINK_BASE=s3a://tick-vault/bronze
# CHECKPOINT_DIR=s3a://tick-vault/flink-checkpoints
# Production (GCS + workload identity / SA on the Flink cluster):
# BRONZE_SINK_BASE=gs://YOUR_BUCKET/bronze
# CHECKPOINT_DIR=gs://YOUR_BUCKET/flink-checkpoints

# --- Phase 2 → BigQuery (scripts: sync_bronze_minio_to_gcs, bronze_to_gcs_and_bq, phase2_* ) ---
# GCS_BUCKET=your-bucket-name   (no gs:// prefix; avoid trailing spaces)
# GCP_CLIENT_EMAIL=service-account@your-gcp-project-id.iam.gserviceaccount.com
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# Optional: with Docker profile "gcs", wait before MinIO→GCS (give Flink time after compose up)
# GCS_PIPELINE_WAIT_SECONDS=120
# Optional: enable profile gcs on every `docker compose up` (same as passing --profile gcs)
# COMPOSE_PROFILES=gcs

# --- Phase 3: Grafana (docker compose --profile grafana) ---
# GF_ADMIN_PASSWORD=change-me
# GOLD_DATASET=tickvault_gold
# DLQ_ALERT_THRESHOLD=25
# JWT fields from keys/gcs.json → .env (no private key in .env; mount keys/gcs.json):
#   python3 scripts/sync_grafana_env_from_sa.py
# GCP_PROJECT_ID=...
# GCP_CLIENT_EMAIL=...
# GCP_TOKEN_URI=https://oauth2.googleapis.com/token

# --- Optional: keep dbt SA path in .env then `source .env` before ./scripts/dbt_build.sh ---
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# --- Optional: Airflow batch stack (airflow/docker-compose.yml) ---
# Export DOCKER_GID from host: stat -c '%g' /var/run/docker.sock  (Linux/WSL)
# TICKVAULT_AIRFLOW_SCHEDULE=@hourly   # or None for manual-only triggers
# MINIO_ENDPOINT=http://127.0.0.1:9000

# --- Optional: Terraform (terraform/) — set GCS_BUCKET to the bucket name after apply ---
